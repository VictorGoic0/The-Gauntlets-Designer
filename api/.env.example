# Copy to .env and fill in. Loaded by app.config (python-dotenv).

# AI providers
OPENAI_API_KEY=sk-proj-your-key-here
GROK_API_KEY=xai-your-key-here

# Firebase Admin (use file path locally, or JSON string on hosts like Railway)
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Upstash (rate limits on /api/agent/*). Omit both to disable limits locally.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# App
APP_ENV=development
LOG_LEVEL=INFO
# LOG_JSON=1
PORT=8000
